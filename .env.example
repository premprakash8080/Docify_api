# ---- AWS SES (transactional email) ----
SES_REGION=ap-south-1
SES_KEY_ID=AKIAxxxxxxxxxxxxxxxx
SES_ACCESS_KEY=your_aws_secret_access_key
# Verified sender used by SendEmailCommand (currently hardcoded in nodemailer.js — move it here)
SES_FROM_EMAIL=no-reply@yourdomain.com

# ---- Cloudinary (file & image uploads) ----
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
CLOUDINARY_FOLDER=docify-uploads

# ---- Frontend / CORS ----
# Currently CORS is wide-open in server.js — recommended to restrict to this origin.
FRONTEND_URL=http://localhost:5173
CORS_ORIGIN=http://localhost:5173

# ---- (Optional) Nodemailer SMTP fallback ----
# Only needed if you switch from AWS SES back to SMTP.
# NODEMAILER_USER=
# NODEMAILER_PASS=
# EMAIL_FROM=
