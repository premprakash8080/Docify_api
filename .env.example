# ============================================================
# Docify API — Environment Variables
# Copy this file to `.env` and fill in real values.
# Never commit your real `.env` (already in .gitignore).
# ============================================================

# ---- App ----
# One of: development | testing | production
NODE_ENV=development
PORT=2017

# ---- MySQL (Sequelize) ----
DB_HOST=localhost
DB_PORT=3306
DB_NAME=docify
DB_USER=root
DB_PASS=root
DB_DIALECT=mysql

# ---- JWT ----
# Use long, random, high-entropy secrets (e.g. `openssl rand -base64 64`)
JWT_PRIVATE_KEY=replace_with_64_byte_random_string
JWT_PRIVATE_KEY_RESET_PASSWORD=replace_with_separate_64_byte_random_string

# ---- Firebase Admin SDK ----
# From your Firebase service-account JSON.
# IMPORTANT: keep the literal "\n" sequences in the private key —
# the code already converts them to real newlines.
